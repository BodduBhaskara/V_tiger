<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">
<suite name="Suite" thread-count="3" parallel="tests">
<listeners>
<listener class-name="ListenerUtility.Listeners"></listener>
</listeners>
  <test  name="Test-chrome">
  <parameter name="Browser" value="chrome"></parameter>
    <classes>
      <class name="organization_module.OrganizationModuleTest"/>
      <class name="Contact_Module.ContactModuleTest"/>
    </classes>
  </test> <!-- Test -->
  <test  name="Test-edge">
  <parameter name="Browser" value="edge"></parameter>
    <classes>
      <class name="organization_module.OrganizationModuleTest"/>
      <class name="Contact_Module.ContactModuleTest"/>
    </classes>
  </test> <!-- Test -->
  <test  name="Test-firefox">
  <parameter name="Browser" value="firefox"></parameter>
    <classes>
      <class name="organization_module.OrganizationModuleTest"/>
      <class name="Contact_Module.ContactModuleTest"/>
    </classes>
  </test> <!-- Test -->
</suite> <!-- Suite -->
